@startuml Декомпозиция уровень 0 - Контекстная диаграмма
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 12

actor "Пользователь" as User
database "Локальное\nхранилище" as Storage
cloud "Удалённый\nсервер" as Server

rectangle "Система\nOffline EDM" as System {
}

User --> System : Создание документов
User --> System : Согласование
User --> System : Подписание
User --> System : Просмотр
System --> User : Отображение документов
System --> User : Уведомления

System --> Storage : Сохранение данных
Storage --> System : Загрузка данных

System --> Server : Синхронизация
Server --> System : Обновления

@enduml
