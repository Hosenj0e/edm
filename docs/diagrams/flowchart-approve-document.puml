@startuml Согласование документа
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 12

start
:Начало;

:Пользователь выбирает
документ и нажимает
"Согласовать";

:Получение идентификатора
документа docId;

:Вызов функции
approveDocument(docId);

if (DocumentService\nинициализирован?) then (Нет)
  :Вывод сообщения
  об ошибке;
  stop
else (Да)
endif

:Получение текущего
статуса документа из БД;

if (Статус =\n"На согласовании"?) then (Нет)
  :Вывод сообщения:
  "Документ не может
  быть согласован";
  stop
else (Да)
endif

:Обновление статуса
на "Согласован";

:Обновление времени
updated_at;

:Сохранение записи
в таблицу approvals;

if (Данные успешно\nсохранены?) then (Нет)
  :Вывод сообщения
  об ошибке записи;
  stop
else (Да)
endif

:Получение версии
документа;

:Добавление задачи APPROVE
в очередь синхронизации;

:Обновление модели
DocumentListModel;

:Отправка сигнала
documentsModelChanged;

:Обновление UI:
статус "Согласован";

:Конец;
stop

@enduml
