@startuml Создание документа
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 12

start
:Начало;

:Пользователь вводит
название и содержимое
документа;

:Вызов функции
createDocument();

if (DocumentService\nинициализирован?) then (Нет)
  :Вывод сообщения
  об ошибке;
  stop
else (Да)
endif

:Генерация уникального
идентификатора UUID;

:Вычисление хеша
SHA-256 от содержимого;

:Шифрование содержимого
алгоритмом AES-256-CBC;

:Запись зашифрованного
файла в vault/;

if (Файл успешно\nзаписан?) then (Нет)
  :Вывод сообщения
  об ошибке записи;
  stop
else (Да)
endif

:Сохранение метаданных
в таблицу documents;

:Создание записи
в таблицу approvals;

if (Данные успешно\nсохранены в БД?) then (Нет)
  :Вывод сообщения
  об ошибке БД;
  stop
else (Да)
endif

:Добавление задачи
синхронизации в очередь;

:Обновление модели
DocumentListModel;

:Отправка сигнала
documentsModelChanged;

:Обновление списка
документов в UI;

:Конец;
stop

@enduml
