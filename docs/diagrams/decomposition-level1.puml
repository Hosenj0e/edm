@startuml Декомпозиция уровень 1 - Основные подсистемы
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 12

actor "Пользователь" as User

package "Система Offline EDM" {
    rectangle "1.0\nПодсистема\nаутентификации" as Auth
    rectangle "2.0\nПодсистема\nуправления\nдокументами" as DocMgmt
    rectangle "3.0\nПодсистема\nбезопасности" as Security
    rectangle "4.0\nПодсистема\nсинхронизации" as Sync
}

database "accounts.sqlite" as AuthDB
database "documents.sqlite" as DocDB
database "sync.sqlite" as SyncDB
folder "vault/" as Vault
cloud "Удалённый сервер" as Server

User --> Auth : Логин, пароль
Auth --> User : Результат авторизации
Auth --> AuthDB : Проверка учётных данных
AuthDB --> Auth : Данные пользователя

User --> DocMgmt : Операции с документами
DocMgmt --> User : Список документов
DocMgmt --> DocDB : Метаданные
DocDB --> DocMgmt : Данные документов
DocMgmt --> Security : Запрос шифрования
Security --> DocMgmt : Зашифрованные данные
Security --> Vault : Сохранение файлов
Vault --> Security : Чтение файлов

DocMgmt --> Sync : Задачи синхронизации
Sync --> SyncDB : Очередь задач
SyncDB --> Sync : Задачи для отправки
Sync --> Server : Данные для синхронизации
Server --> Sync : Подтверждение

@enduml
