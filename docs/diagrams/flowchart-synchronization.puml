@startuml Синхронизация с сервером
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 12

start
:Начало;

:Инициализация
SyncEngine;

:Проверка подключения
к интернету;

if (Интернет\nдоступен?) then (Нет)
  :Ожидание восстановления
  подключения;
  stop
else (Да)
endif

:Получение задач из
таблицы sync_queue;

if (Очередь пуста?) then (Да)
  :Конец;
  stop
else (Нет)
endif

:Взять первую задачу
из очереди;

:Определение типа
операции;

if (Тип операции?) then (CREATE)
  :Отправка данных
  о создании документа
  на сервер;
elseif (APPROVE) then
  :Отправка данных
  о согласовании
  на сервер;
elseif (SIGN) then
  :Отправка данных
  о подписании
  на сервер;
endif

:Ожидание ответа
от сервера;

if (Ответ успешен?) then (Нет)
  if (Попыток < 3?) then (Да)
    :Увеличить счётчик
    попыток;
    :Ожидание 5 секунд;
    stop
  else (Нет)
    :Пометить задачу
    как failed;
  endif
else (Да)
  :Удалить задачу
  из очереди;
  :Отправка сигнала
  pendingSyncTasksChanged;
endif

:Переход к следующей
задаче в очереди;

:Конец;
stop

@enduml
