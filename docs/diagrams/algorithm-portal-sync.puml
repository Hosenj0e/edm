@startuml
!define RECTANGLE class
skinparam defaultTextAlignment center
skinparam backgroundColor white
skinparam shadowing false

skinparam activity {
  BackgroundColor white
  BorderColor black
  FontName Arial
  FontSize 11
}

start
:Ввод параметров:
- login, password
- groupsIndexUrl
- sessionStorePath|

if (Используется\nсохранённая сессия?) then (да)
  if (Файл cookies существует?) then (да)
    :Загрузить cookies из файла;
    :Установить Step = CheckingSession;
  else (нет)
    :Запустить локальный импорт
    из папки portal-html|
    stop
  endif
else (нет)
  :Установить Step = LoadingHome;
endif

:Установить m_busy = true;
:Отправить сигнал busyChanged(true);
:Установить прогресс: "Запуск...", 0%;

if (Step == LoadingHome?) then (да)
  :HTTP GET: https://portal.novsu.ru/;
  :Ожидание ответа...;
  :Парсинг HTML главной страницы;
  :Извлечь форму входа:
  - action URL
  - hidden поля (csrf token)|
  :Установить Step = PostingLogin;
  :HTTP POST: отправка формы
  с логином и паролем;
else (нет)
endif

:Ожидание ответа авторизации...;

if (Страница содержит\nформу входа?) then (да)
  :Ошибка: "Неверный логин или пароль"|
  :Установить m_busy = false;
  :Отправить сигнал failed();
  stop
else (нет)
  :Авторизация успешна;
endif

:Сохранить cookies в файл;
:Установить Step = LoadingIndex;
:HTTP GET: groupsIndexUrl;

:Ожидание ответа...;
:Парсинг HTML страницы со списком групп;
:Извлечь все ссылки на страницы групп
(regex: /student/contingent/group/\\d+)|

:Сохранить список URL в m_groupUrls;
:Установить m_groupIndex = 0;
:Установить Step = LoadingGroup;

while (m_groupIndex < m_groupUrls.size()?) is (да)
  :Получить URL текущей группы;
  :HTTP GET: URL группы;
  :Ожидание ответа...;
  :Парсинг HTML страницы группы;
  
  :Извлечь данные группы:
  - номер группы
  - год поступления
  - курс
  - специальность
  - профиль
  - институт
  - форма обучения|
  
  :Вызов upsertGroupFromPortal()
  (создать или обновить группу в БД);
  
  :Извлечь список студентов:
  - номер студента
  - ФИО
  - статус (обучается/отчислен)|
  
  :Вызов mergePortalStudents()
  (добавить новых студентов в БД);
  
  :m_groupsImported++;
  :m_studentsAdded += count;
  :m_groupIndex++;
  
  :Обновить прогресс:
  "Обработано групп: X из Y",
  процент = (X / Y) * 100|
endwhile (нет)

:Установить Step = Done;
:Сохранить cookies;
:Обновить список групп в UI;
:Отправить сигнал finished(
  m_groupsImported,
  m_studentsAdded)|
:Установить m_busy = false;

stop

@enduml
