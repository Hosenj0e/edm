@startuml
!define RECTANGLE class
skinparam defaultTextAlignment center
skinparam backgroundColor white
skinparam shadowing false

skinparam activity {
  BackgroundColor white
  BorderColor black
  FontName Arial
  FontSize 11
}

start
:Ввод данных:
- login
- password
- displayName
- role|

:Нормализация логина:
- toLower()
- trim()
- замена пробелов на "_"|

if (Длина логина 3-48 символов\nИ только буквы, цифры, _, -?) then (нет)
  :Установить ошибку:
  "Логин: 3–48 символов,
  только буквы, цифры, _ и -"|
  :Возврат false|
  stop
else (да)
endif

if (Длина пароля >= 6?) then (нет)
  :Установить ошибку:
  "Пароль не короче 6 символов"|
  :Возврат false|
  stop
else (да)
endif

:Обрезать пробелы из displayName;

if (displayName не пустое?) then (нет)
  :Установить ошибку:
  "Укажите отображаемое имя"|
  :Возврат false|
  stop
else (да)
endif

:Открыть БД accounts.sqlite;

if (БД открыта?) then (нет)
  :Установить ошибку:
  "Не удалось открыть БД"|
  :Возврат false|
  stop
else (да)
endif

:SQL-запрос:
SELECT 1 FROM users
WHERE login = ?;

if (Логин уже существует?) then (да)
  :Установить ошибку:
  "Такой логин уже занят"|
  :Возврат false|
  stop
else (нет)
endif

:Генерация случайной соли:
randomSalt(16 байт);

:Вычисление hash пароля:
PBKDF2-SHA256(
  password,
  salt,
  120000 итераций,
  32 байта)|

:Получить текущее время:
QDateTime::currentMSecsSinceEpoch();

:SQL-запрос INSERT:
INSERT INTO users
(login, display_name, salt,
password_hash, created_at, role)
VALUES (?, ?, ?, ?, ?, ?)|

if (Вставка успешна?) then (нет)
  :Установить ошибку:
  "Не удалось сохранить пользователя"|
  :Возврат false|
  stop
else (да)
endif

:Создать папку пользователя:
users/{login}/;

:Установить переменные сессии:
- m_login = login
- m_displayName = displayName
- m_role = role;

:Отправить сигнал
sessionChanged()|

:Возврат true|

stop

@enduml
