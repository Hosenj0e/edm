@startuml Аутентификация пользователя
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 12

start
:Начало;

:Запуск приложения;

:Проверка наличия
файла accounts.sqlite;

if (База данных\nсуществует?) then (Нет)
  :Создание базы данных
  и таблицы users;
else (Да)
endif

:Проверка наличия
пользователя admin;

if (Пользователь admin\nсуществует?) then (Нет)
  :Создание пользователя
  admin с паролем 123;
else (Да)
endif

:Отображение окна
авторизации LoginPage;

:Пользователь вводит
логин и пароль;

:Нажатие кнопки "Войти";

if (Поля заполнены?) then (Нет)
  :Вывод сообщения:
  "Заполните все поля";
  stop
else (Да)
endif

:Вычисление хеша пароля
PBKDF2-SHA256
(100000 итераций);

:Запрос к БД:
SELECT * FROM users
WHERE login = ?;

if (Пользователь\nнайден?) then (Нет)
  :Вывод сообщения:
  "Неверный логин";
  stop
else (Да)
endif

if (Хеш пароля\nсовпадает?) then (Нет)
  :Вывод сообщения:
  "Неверный пароль";
  stop
else (Да)
endif

:Сохранение текущего
пользователя в сессии;

:Вызов функции
openSession();

:Инициализация сервисов:
KeyManager,
DocumentService,
SyncEngine;

:Загрузка документов
пользователя из БД;

:Отображение главного
окна Main.qml;

:Конец;
stop

@enduml
