@startuml Подписание документа
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 12

start
:Начало;

:Пользователь выбирает
документ и нажимает
"Подписать";

:Получение идентификатора
документа docId;

:Вызов функции
signDocument(docId);

if (DocumentService\nинициализирован?) then (Нет)
  :Вывод сообщения
  об ошибке;
  stop
else (Да)
endif

:Получение текущего
статуса документа из БД;

if (Статус =\n"Согласован"?) then (Нет)
  :Вывод сообщения:
  "Документ должен быть
  сначала согласован";
  stop
else (Да)
endif

:Получение хеша
content_hash из БД;

if (Хеш найден?) then (Нет)
  :Вывод сообщения
  об ошибке;
  stop
else (Да)
endif

:Генерация цифровой
подписи HMAC-SHA256
от хеша документа;

:Обновление статуса
на "Подписан";

:Сохранение подписи
в таблицу signatures;

if (Данные успешно\nсохранены?) then (Нет)
  :Вывод сообщения
  об ошибке записи;
  stop
else (Да)
endif

:Получение версии
документа;

:Добавление задачи SIGN
в очередь синхронизации;

:Обновление модели
DocumentListModel;

:Отправка сигнала
documentsModelChanged;

:Обновление UI:
статус "Подписан";

:Конец;
stop

@enduml
