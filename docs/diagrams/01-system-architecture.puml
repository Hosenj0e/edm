@startuml System Architecture
!define RECTANGLE class

skinparam backgroundColor #FFFFFF
skinparam componentStyle rectangle

package "Presentation Layer (QML)" {
    [App.qml] as App
    [LoginPage.qml] as Login
    [Main.qml] as Main
}

package "Application Layer (C++)" {
    [AuthController] as AuthCtrl
    [AppController] as AppCtrl
    [DocumentListModel] as DocModel
}

package "Business Logic Layer" {
    [DocumentService] as DocService
}

package "Security Layer" {
    [KeyManager] as KeyMgr
    [EncryptionService] as Encryption
    [SignatureProvider] as Signature
}

package "Data Access Layer" {
    [SqliteDocumentRepository] as DocRepo
    [EncryptedFileStorage] as FileStorage
    [SqliteSyncQueue] as SyncQueue
}

package "Synchronization Layer" {
    [SyncEngine] as SyncEngine
    [RemoteSyncGateway] as RemoteGW
}

database "Storage" {
    [accounts.sqlite] as AccountsDB
    [documents.sqlite] as DocsDB
    [sync.sqlite] as SyncDB
    folder "vault/" as Vault
}

' Connections
App --> AuthCtrl
App --> AppCtrl
Main --> AppCtrl
Login --> AuthCtrl

AppCtrl --> DocModel
AppCtrl --> DocService
AppCtrl --> SyncEngine

AuthCtrl --> AccountsDB

DocService --> DocRepo
DocService --> FileStorage
DocService --> Signature
DocService --> SyncQueue

FileStorage --> Encryption
Encryption --> KeyMgr
Signature --> KeyMgr

DocRepo --> DocsDB
FileStorage --> Vault
SyncQueue --> SyncDB

SyncEngine --> SyncQueue
SyncEngine --> RemoteGW

@enduml
